[gd_scene format=3 uid="uid://df234df3ping1"]

[sub_resource type="GDScript" id="GDScript_ping"]
script/source = "extends Node3D

var lifetime = 2.0
var age = 0.0

func _process(delta):
	age += delta
	if age >= lifetime:
		queue_free()
	else:
		var s = 1.0 + (age * 2.0)
		scale = Vector3(s, s, s)
		var mat = $MeshInstance3D.mesh.surface_get_material(0)
		if mat:
			mat.albedo_color.a = 1.0 - (age / lifetime)
"

